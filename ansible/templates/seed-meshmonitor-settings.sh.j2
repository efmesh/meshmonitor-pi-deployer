#!/usr/bin/env bash
# Electric Forest turnkey MeshMonitor automation seeder.
#
# Rendered by Ansible from seed-meshmonitor-settings.sh.j2. Logs into a fresh
# MeshMonitor instance, sets the admin password, and seeds a turnkey set of
# Electric Forest automations (auto-ack, auto-ping, auto-responder, auto-welcome,
# and a sunrise announce). Idempotent: records the applied seed version in a
# marker file and exits early on reruns unless FORCE_SEED is set.
#
# MeshMonitor's /api/settings endpoint only persists recognized setting keys
# (unknown keys are silently dropped), so the seed version is tracked on the Pi
# via {{ meshmonitor_seed_marker_file }} rather than as a setting.
set -euo pipefail

BASE_URL="{{ meshmonitor_seed_url }}"
# The admin password is passed via the environment by the Ansible task rather
# than templated into this file, so it never lands on disk and shell
# metacharacters ($, backticks, quotes) in it are never interpreted.
ADMIN_PASSWORD="${EF_SEED_ADMIN_PASSWORD:?EF_SEED_ADMIN_PASSWORD must be set in the environment}"
SEED_VERSION="{{ efmesh_seed_version }}"
FORCE_SEED="{{ ef_force_seed | lower }}"
MARKER_FILE="{{ meshmonitor_seed_marker_file }}"

COOKIE_JAR="$(mktemp)"
trap 'rm -f "$COOKIE_JAR"' EXIT

log() { printf '[ef-seed] %s\n' "$*"; }
warn() { printf '[ef-seed][WARNING] %s\n' "$*" >&2; }
fail() { printf '[ef-seed][ERROR] %s\n' "$*" >&2; exit 1; }

# --- Validate admin password -------------------------------------------------
# MeshMonitor enforces an 8-character minimum on the admin password (see
# change-password in MeshMonitor's localAuth). If a shorter password slips
# through, the change-password call below returns HTTP 400 and the instance is
# left on the default 'changeme' — a silent security footgun. Catch it here with
# a clear message instead of a cryptic mid-run failure.
if [ "$(printf '%s' "$ADMIN_PASSWORD" | wc -c)" -lt 8 ]; then
  fail "Admin password must be at least 8 characters (MeshMonitor requirement). Re-run with a longer MESHMONITOR_ADMIN_PASSWORD."
fi

# --- Idempotency -------------------------------------------------------------
if [ "$FORCE_SEED" != "true" ] && [ -f "$MARKER_FILE" ]; then
  CURRENT="$(cat "$MARKER_FILE" 2>/dev/null || echo 0)"
  if [ "${CURRENT:-0}" -ge "$SEED_VERSION" ] 2>/dev/null; then
    log "Already seeded at version $CURRENT (>= $SEED_VERSION); nothing to do."
    exit 0
  fi
fi

# --- Wait for MeshMonitor HTTP -----------------------------------------------
log "Waiting for MeshMonitor to come up at $BASE_URL ..."
UP=false
for _ in $(seq 1 150); do
  if curl -fsS "$BASE_URL/api/csrf-token" >/dev/null 2>&1; then
    UP=true
    break
  fi
  sleep 2
done
[ "$UP" = "true" ] || fail "MeshMonitor did not become reachable within ~300s"
log "MeshMonitor is up."

# --- Helpers -----------------------------------------------------------------
get_csrf() {
  curl -fsS -c "$COOKIE_JAR" -b "$COOKIE_JAR" "$BASE_URL/api/csrf-token" \
    | sed 's/.*"csrfToken":"//; s/".*//'
}

# login <password> -> echoes HTTP status code
login() {
  local pw="$1" csrf code
  csrf="$(get_csrf)"
  code="$(curl -s -o /dev/null -w '%{http_code}' \
    -c "$COOKIE_JAR" -b "$COOKIE_JAR" \
    -X POST "$BASE_URL/api/auth/login" \
    -H 'Content-Type: application/json' \
    -H "X-CSRF-Token: $csrf" \
    --data "$(python3 -c 'import json,sys; print(json.dumps({"username":"admin","password":sys.argv[1]}))' "$pw")")"
  printf '%s' "$code"
}

# --- Authenticate ------------------------------------------------------------
# A fresh MeshMonitor ships with admin/changeme only, so on the FIRST deploy a
# login with your configured password legitimately returns 401 — that is
# expected, not an error. We then log in with the default and immediately change
# the password to yours. On reruns your configured password already works and we
# skip straight through. The invariant on exit: the instance is on YOUR password,
# never on 'changeme'.
log "Authenticating ..."
CODE="$(login "$ADMIN_PASSWORD")"
if [ "$CODE" = "200" ]; then
  log "Logged in with your configured admin password (already set on a prior deploy)."
elif [ "$CODE" = "401" ]; then
  log "First deploy: your password isn't set yet, logging in with the MeshMonitor default to set it ..."
  CODE="$(login "changeme")"
  [ "$CODE" = "200" ] || fail "Could not log in with your configured password OR the default 'changeme'. The instance may already have a different admin password set, or admin setup hasn't finished — check the MeshMonitor container logs. (HTTP $CODE)"
  log "Logged in with default credentials; changing the admin password to yours ..."
  CSRF="$(get_csrf)"
  CHBODY_FILE="$(mktemp)"
  CHCODE="$(curl -s -o "$CHBODY_FILE" -w '%{http_code}' \
    -c "$COOKIE_JAR" -b "$COOKIE_JAR" \
    -X POST "$BASE_URL/api/auth/change-password" \
    -H 'Content-Type: application/json' \
    -H "X-CSRF-Token: $CSRF" \
    --data "$(python3 -c 'import json,sys; print(json.dumps({"currentPassword":"changeme","newPassword":sys.argv[1]}))' "$ADMIN_PASSWORD")")"
  if [ "$CHCODE" != "200" ]; then
    warn "MeshMonitor rejected the password change (HTTP $CHCODE):"
    cat "$CHBODY_FILE" >&2 || true
    rm -f "$CHBODY_FILE"
    fail "Password change FAILED. The instance is still on the default 'changeme' — log in and change it manually, then re-run. (Common cause: password shorter than 8 characters.)"
  fi
  rm -f "$CHBODY_FILE"
  log "Password changed. Re-authenticating with your new password ..."
  CODE="$(login "$ADMIN_PASSWORD")"
  [ "$CODE" = "200" ] || fail "Re-login after password change failed (HTTP $CODE). The instance may be in an inconsistent auth state — check the container logs."
else
  fail "Unexpected login response (HTTP $CODE). Check that MeshMonitor finished starting and that admin setup completed."
fi

# Belt-and-suspenders: confirm 'changeme' no longer works, so we can never
# silently report success while the instance is left on the default password.
DEFCHECK="$(login "changeme")"
if [ "$DEFCHECK" = "200" ]; then
  fail "SECURITY: the default 'changeme' password still works after seeding. Your configured password was NOT applied. Log in and change it manually, then re-run."
fi
# Restore our authenticated session for the settings POST below (the changeme
# probe above replaced the session cookie).
login "$ADMIN_PASSWORD" >/dev/null

# --- Seed settings -----------------------------------------------------------
# All values are flat strings. Camp and morning message are substituted via
# Jinja2 with the to_json filter so quotes / emoji are escaped safely.
log "Seeding Electric Forest automation settings ..."
PAYLOAD_FILE="$(mktemp)"
trap 'rm -f "$COOKIE_JAR" "$PAYLOAD_FILE"' EXIT
cat > "$PAYLOAD_FILE" <<'PAYLOAD'
{{ ef_seed_settings | to_nice_json(indent=2) }}
PAYLOAD

CSRF="$(get_csrf)"
RESP_FILE="$(mktemp)"
HTTP="$(curl -s -o "$RESP_FILE" -w '%{http_code}' \
  -c "$COOKIE_JAR" -b "$COOKIE_JAR" \
  -X POST "$BASE_URL/api/settings" \
  -H 'Content-Type: application/json' \
  -H "X-CSRF-Token: $CSRF" \
  --data @"$PAYLOAD_FILE")"
if [ "$HTTP" != "200" ]; then
  log "Settings POST returned HTTP $HTTP; body:"
  cat "$RESP_FILE" >&2 || true
  rm -f "$RESP_FILE"
  fail "Seeding settings failed"
fi
rm -f "$RESP_FILE"
log "Settings POST accepted (HTTP 200)."

# --- Verify ------------------------------------------------------------------
log "Verifying seeded settings ..."
VERIFY_FILE="$(mktemp)"
curl -fsS -c "$COOKIE_JAR" -b "$COOKIE_JAR" "$BASE_URL/api/settings" -o "$VERIFY_FILE" \
  || fail "Could not read back settings for verification"

VERIFY_RC=0
python3 - "$VERIFY_FILE" "$PAYLOAD_FILE" <<'PYEOF' || VERIFY_RC=$?
import json, sys
with open(sys.argv[1]) as fh:
    current = json.load(fh)
with open(sys.argv[2]) as fh:
    seeded = json.load(fh)

# Spot-check a representative set of keys actually landed.
required = [
    "autoAckEnabled", "autoAckChannels", "autoPingEnabled",
    "autoResponderEnabled", "autoResponderTriggers", "autoWelcomeEnabled",
    "autoAnnounceEnabled", "autoAnnounceSchedule", "autoAnnounceMessage",
    "autoAckMessage",
]
missing = [k for k in required if k not in current]
if missing:
    sys.stderr.write("[ef-seed][ERROR] keys missing after seed: %s\n" % ", ".join(missing))
    sys.exit(1)

mismatched = []
for k in required:
    if str(current.get(k)) != str(seeded.get(k)):
        mismatched.append(k)
if mismatched:
    sys.stderr.write("[ef-seed][ERROR] keys did not match seeded values: %s\n" % ", ".join(mismatched))
    sys.exit(1)

print("[ef-seed] Verified %d key(s) present and matching." % len(required))
PYEOF
rm -f "$VERIFY_FILE"
[ "$VERIFY_RC" -eq 0 ] || fail "Verification failed"

# --- Record seed version -----------------------------------------------------
printf '%s\n' "$SEED_VERSION" > "$MARKER_FILE"
log "Seed complete. Recorded seed version $SEED_VERSION at $MARKER_FILE."
log "Admin login is 'admin' with the password you configured (the default 'changeme' is no longer valid)."
