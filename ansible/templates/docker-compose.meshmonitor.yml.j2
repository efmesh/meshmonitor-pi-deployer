services:
{% if meshmonitor_radio_connection_type == 'bluetooth' %}
  meshtastic-ble-bridge:
    image: "{{ meshtastic_ble_bridge_image }}"
    container_name: meshtastic-ble-bridge
    restart: unless-stopped
    privileged: true
    command: {{ meshmonitor_radio_mac }}
    volumes:
      - /var/run/dbus:/var/run/dbus
{% endif %}

  meshmonitor:
    image: "{{ meshmonitor_image }}"
    container_name: meshmonitor
    restart: unless-stopped
    environment:
      MESHMONITOR_RADIO_CONNECTION_TYPE: "{{ meshmonitor_radio_connection_type }}"
      # Allow the web UI to be reached from any LAN origin (Pi IP, hostname, etc.).
      ALLOWED_ORIGINS: "*"
      # Container timezone so the sunrise announce cron fires Rothbury-local.
      TZ: "{{ meshmonitor_timezone }}"
      # Persisted across deploys (Ansible generates it once if absent).
      SESSION_SECRET: "{{ meshmonitor_session_secret }}"
{% if meshmonitor_radio_connection_type == 'bluetooth' %}
      # MeshMonitor bluetooth mode: use meshtastic-ble-bridge on the Docker network.
      MESHTASTIC_NODE_IP=127.0.0.1
      MESHTASTIC_TCP_PORT=4403
{% else %}
      # MeshMonitor can use this to target a wifi transport path.
      MESHTASTIC_NODE_IP="{{ meshmonitor_radio_ip }}"
{% endif %}
{% if meshmonitor_radio_connection_type == 'bluetooth' %}
    depends_on:
      - meshtastic-ble-bridge
{% endif %}
    volumes:
      # Persist MeshMonitor database, session store, VAPID keys, and settings.
      - {{ meshmonitor_data_dir }}:/data
{% if meshmonitor_radio_connection_type == 'bluetooth' %}
      - /var/run/dbus:/var/run/dbus
{% endif %}
    ports:
      - "{{ meshmonitor_http_port }}:{{ meshmonitor_container_port }}"
