# Minimal config
# Pi target for Ansible SSH
TARGET_PI_IP=CHANGE_THIS_TO_YOUR_PI_IP
# Optional: if set, run scripts can use this without retyping each run
# TARGET_PI_PASSWORD=

# Optional SSH settings
PI_USERNAME=pi
# Change PI_USERNAME if your Pi uses a different username with sudo access.

# Radio mode

# WiFi ---------------- Comment this section out to use Bluetooth instead.
# Wifi is the default mode.
RADIO_CONNECTION_TYPE=wifi
RADIO_IP=CHANGE_THIS_TO_YOUR_RADIO_IP
# End of WiFi mode

# Bluetooth ---------------- Uncomment this section to use Bluetooth instead of WiFi. Make sure to fill in the MAC address of your radio.
# You can find the MAC address of your radio when you follow the docs/BLUETOOTH_GUIDE.md guide for pairing.
# RADIO_CONNECTION_TYPE=bluetooth
# RADIO_MAC=AA:BB:CC:DD:EE:FF
# End of Bluetooth mode

# Advanced overrides (optional)
# PI_SSH_PORT=22
# DEPLOYER_IMAGE_NAME=meshmonitor-deployer:latest
# MESHMONITOR_IMAGE=ghcr.io/yeraze/meshmonitor:latest
# MESHMONITOR_HTTP_PORT=8080
# MESHTASTIC_BLE_BRIDGE_IMAGE=ghcr.io/meshtastic/meshtastic-ble-bridge:latest
# MESHTASTIC_BLE_BRIDGE_PORT=4403
