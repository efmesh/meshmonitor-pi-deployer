# Minimal config
# Pi target for Ansible SSH
TARGET_PI_IP=CHANGE_THIS_TO_YOUR_PI_IP
# Optional: if set, run scripts can use this without retyping each run
# TARGET_PI_PASSWORD=

# Optional SSH settings
# The SSH username for your Pi. Default is "pi", but Raspberry Pi OS no longer
# creates a "pi" user by default — set this to whatever username you created
# during Pi setup (it must have sudo access). The deploy scripts also prompt for
# this interactively, so you can leave it commented out.
PI_USERNAME=pi

# Radio mode

# WiFi ---------------- Comment this section out to use Bluetooth instead.
# Wifi is the default mode.
RADIO_CONNECTION_TYPE=wifi
RADIO_IP=CHANGE_THIS_TO_YOUR_RADIO_IP
# End of WiFi mode

# Bluetooth ---------------- Uncomment this section to use Bluetooth instead of WiFi. Make sure to fill in the MAC address of your radio.
# You can find the MAC address of your radio when you follow the docs/BLUETOOTH_GUIDE.md guide for pairing.
# RADIO_CONNECTION_TYPE=bluetooth
# RADIO_MAC=AA:BB:CC:DD:EE:FF
# End of Bluetooth mode

# Electric Forest turnkey automations ------------------------------------------
# When deployed, the playbook seeds MeshMonitor with a turnkey set of Electric
# Forest automations (auto-ack, auto-ping, auto-responder, auto-welcome, and a
# sunrise announce). See docs/EF_AUTOMATIONS.md for the full list.

# Your camp / location label. Used in seeded auto-ack messages, e.g.
# "Got you in 2 hops at Lucky Lake". If unset, the deploy script prompts you
# with a camp picker. Examples: "GA Campgrounds", "Camp Higher Love",
# "Lucky Lake", "GA Loop 5 by the showers".
# EF_CAMP=Lucky Lake

# MeshMonitor admin password to set on first deploy (REQUIRED by the seeder).
# Fresh MeshMonitor installs ship with admin/changeme; the seeder logs in,
# changes the password to this value, then seeds settings. If unset, the deploy
# script prompts you (silent input).
# Requirements (enforced by MeshMonitor):
#   - at least 8 characters
#   - must not be empty or "changeme"
# Any characters are allowed, including spaces, emoji, and shell metacharacters
# ($, backticks, quotes) — the password is passed through safely and never
# shell-interpreted. On the first deploy you'll see a log line saying it logged
# in with the default to set your password; that is expected, not an error.
# MESHMONITOR_ADMIN_PASSWORD=

# Optional. The sunrise "Good Morning" message announced to forest-chat
# (channel 2) at 6:05 AM America/Detroit. Defaults to
# "🌅 Good Morning from <EF_CAMP>! ☀️🌲" with your camp substituted in.
# EF_MORNING_MESSAGE=🌅 Good Morning from Lucky Lake! ☀️🌲

# Optional. Set to "true" to re-seed automations even if this Pi was already
# seeded at the current seed version. Normally reruns are a no-op once seeded.
# FORCE_SEED=false

# Advanced overrides (optional)
# PI_SSH_PORT=22
# DEPLOYER_IMAGE_NAME=meshmonitor-deployer:latest
# MESHMONITOR_IMAGE=ghcr.io/yeraze/meshmonitor:latest
# MESHMONITOR_HTTP_PORT=8080
# MESHTASTIC_BLE_BRIDGE_IMAGE=ghcr.io/yeraze/meshtastic-ble-bridge:latest
# MESHTASTIC_BLE_BRIDGE_PORT=4403
